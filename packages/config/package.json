{
  "name": "@neststack/config",
  "version": "0.0.0",
  "description": "Enterprise-grade, type-safe dynamic configuration module for NestJS with Zod validation, secret masking, and O(1) lookups",
  "license": "MIT",
  "author": "Mike Cojocari",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikecoj/neststack-advanced-packages.git",
    "directory": "packages/config"
  },
  "bugs": {
    "url": "https://github.com/mikecoj/neststack-advanced-packages/issues"
  },
  "homepage": "https://github.com/mikecoj/neststack-advanced-packages/tree/main/packages/config#readme",
  "keywords": [
    "nestjs",
    "config",
    "configuration",
    "zod",
    "type-safe",
    "enterprise",
    "dynamic-module",
    "secret-masking",
    "validation"
  ],
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "*.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
