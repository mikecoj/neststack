{
  "name": "docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/docs",
  "targets": {
    "lint": {
      "command": "biome lint {projectRoot}"
    },
    "format": {
      "command": "biome format --write {projectRoot}"
    },
    "check": {
      "command": "biome check --write {projectRoot}"
    },
    "dev": {
      "command": "next dev",
      "options": { "cwd": "apps/docs" }
    },
    "build": {
      "command": "next build",
      "options": { "cwd": "apps/docs" },
      "outputs": ["{projectRoot}/out"]
    },
    "postbuild": {
      "command": "pagefind --site out",
      "options": { "cwd": "apps/docs" },
      "dependsOn": ["build"]
    }
  }
}
